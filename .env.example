# Copy to your environment or source before running commands.

# Redis broker (required for enqueue / worker)
BROKER_URL=redis://:password@host:6379/2

# Config file (spapi, offer_service, product_service, …)
AMAZON_SPAPI_CONFIG_PATH=~/.amazon_spapi/config.ini

# Legacy env names still accepted:
# EVERYMARKET_CONFIG_PATH=~/.amazon_spapi/config.ini
# EM_WORKERS_CONFIG_PATH=~/.amazon_spapi/config.ini
# MWS_COLLECTOR_CONFIGURATION_PATH=~/.amazon_spapi/config.ini
