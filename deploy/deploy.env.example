# 一键部署配置（复制为 deploy.env 后修改）
# cp deploy/deploy.env.example deploy/deploy.env

# 运行服务的 Linux 用户（代码在 ~/src 下时通常就是你自己）
DEPLOY_USER=sky

# 项目目录（留空 = /home/<DEPLOY_USER>/src/em-workers）
APP_DIR=

# 全新机器可选：若 APP_DIR 不存在，从此地址 git clone（留空则从当前目录复制）
# GIT_REPO=https://github.com/AriseshineSky/amazon-spapi-workers.git

# 必填：任务队列 Redis 地址
BROKER_URL=redis://:password@127.0.0.1:6379/2

# Worker 参数（写入 /etc/conf.d/celery_spapi，systemd 从此读取）
ENV_FILE=/etc/conf.d/celery_spapi
OFFERS_MARKETPLACES=us,ca,mx
CATALOG_MARKETPLACES=us,ca,mx
OFFERS_WORKER_NAME=c845us-offers
CATALOG_WORKER_NAME=c845us-catalog
OFFERS_CONCURRENCY=1
CATALOG_CONCURRENCY=1
OFFERS_TASK_RATE=16/m
CATALOG_TASK_RATE=1/s
FETCH_PRODUCTS_TASK_RATE=6/m

# systemd 日志级别
CELERY_LOG_LEVEL=info

# 是否在部署完成后自动启动并设为开机自启（true/false）
START_SERVICES=true
